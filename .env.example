LEOTIME_HTTP_ADDR=:8080
LEOTIME_DB_PATH=/data/leotime.db
LEOTIME_STATIC_DIR=/app/public
LEOTIME_BOOTSTRAP_EMAIL=admin@example.com
LEOTIME_BOOTSTRAP_PASSWORD=change-me-now
# Required in production: set LEOTIME_ENV=production and a non-default LEOTIME_BOOTSTRAP_PASSWORD
# LEOTIME_ENV=production
LEOTIME_SESSION_COOKIE=leotime_session
LEOTIME_SESSION_TTL=168h
LEOTIME_COOKIE_SECURE=false

# Background scheduler (still-running timer emails)
LEOTIME_SCHEDULER_ENABLED=true
LEOTIME_SCHEDULER_SCAN_INTERVAL=10m
LEOTIME_OUTBOX_PROCESS_INTERVAL=30s

# Email: log (dev) or smtp (production)
LEOTIME_MAIL_MODE=log
LEOTIME_MAIL_FROM=no-reply@localhost
LEOTIME_MAIL_FROM_NAME=leotime
LEOTIME_PUBLIC_BASE_URL=http://127.0.0.1:8080
# LEOTIME_SMTP_HOST=smtp.example.com
# LEOTIME_SMTP_PORT=587
# LEOTIME_SMTP_USERNAME=
# LEOTIME_SMTP_PASSWORD=
# LEOTIME_SMTP_TLS=true
LEOTIME_MAIL_MAX_ATTEMPTS=5
LEOTIME_MAIL_RETRY_BASE=1m
LEOTIME_MAIL_RETRY_MAX=6h
LEOTIME_PASSWORD_RESET_TTL=1h

# S3 daily backups (credentials stored encrypted; requires 32-byte key)
# Generate: openssl rand -base64 32
LEOTIME_SECRETS_KEY=
LEOTIME_BACKUP_SCHEDULER_ENABLED=true
LEOTIME_BACKUP_SCHEDULER_INTERVAL=1m

# Prometheus /metrics: hidden in production unless set; use Bearer token or ?token=
# LEOTIME_METRICS_TOKEN=

